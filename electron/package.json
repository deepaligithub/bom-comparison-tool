{
  "name": "bom-compare-tool",
  "version": "1.0.12",
  "description": "BOM Compare Tool - Compare two BOM files side by side",
  "main": "main.js",
  "author": "Cinematics",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "copy-static": "node scripts/copy-static.js",
    "pack": "electron-builder --dir",
    "dist": "npm run build --prefix ../frontend && npm run copy-static && electron-builder",
    "dist:msix": "npm run build --prefix ../frontend && npm run copy-static && electron-builder --win msix",
    "release": "npm version patch --no-git-tag-version && npm run dist"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.bomcompare.tool",
    "productName": "BOM Compare Tool",
    "directories": {
      "output": "dist-electron-new",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*"
    ],
    "extraResources": [
      {
        "from": "resources/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/static",
        "to": "static",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "appx",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "appx": {
      "identityName": "Cinematics.BOMCompareTool",
      "publisher": "CN=B334C1F8-5690-4ED6-8595-3ECF0BFE5FEF",
      "publisherDisplayName": "Cinematics"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
