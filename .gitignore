# === FRONTEND IGNORE RULES ===
/frontend/node_modules
/frontend/dist
/frontend/build
/frontend/.env
/frontend/.env.local
/frontend/.env.development.local
/frontend/.env.production.local

# NPM/Yarn logs
/frontend/npm-debug.log*
/frontend/yarn-debug.log*
/frontend/yarn-error.log*

# Editor & system files (frontend)
frontend/.DS_Store

# === BACKEND IGNORE RULES ===
/backend/venv
/backend/__pycache__/
/backend/**/*.py[cod]

/backend/.env
/backend/.env.local

/backend/logs/

# Backend runtime/generated folders
/backend/uploads/
/backend/build/
/backend/dist/
/backend/app/static/
backend/.DS_Store

# Flask instance folder (if used)
backend/instance/

# === GENERAL IGNORE RULES ===
# OS-specific
.DS_Store
Thumbs.db

# VS Code config (optional)
.vscode/

# PyCharm IDE config (optional)
.idea/

# Python egg metadata
*.egg-info/
.eggs/

# Coverage reports
.coverage
htmlcov/
.tox/
.cache/
pytest_cache/
nosetests.xml
coverage.xml
*.cover

# Log files
*.log

# Others
*.swp

# Future: Reports or exports
/backend/exports/
exports/
node_modules

# Electron build outputs
/electron/dist-electron*/
/electron/resources/static/
/electron/resources/backend/

# Package/build artifacts (repo root)
/dist/
/logs/
*.zip
*.appx
*.exe
*.msix
*.docx
.frontend.hash
.vendor_zipapp/
BOMCompareTool-*/
DeploymentPackage/
